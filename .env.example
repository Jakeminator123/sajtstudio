# ---- Server-side secrets (never prefix with NEXT_PUBLIC_) ----
# CONTACTS_API_KEY protects GET /api/contact. Uncomment to require Authorization header.
# CONTACTS_API_KEY=Ma!!orca123

# RESEND_API_KEY is optional but required if you want contact form emails sent via Resend.
# RESEND_API_KEY=

# ---- Client-exposed flags (NEXT_PUBLIC_ prefix) ----
# Mirror CONTACTS_API_KEY so the admin dashboard can send the same value from the browser.
# NEXT_PUBLIC_CONTACTS_API_KEY=Ma!!orca123

# Toggle the D-ID chatbot (disabled by default in production).
# NEXT_PUBLIC_ENABLE_DID_CHATBOT=false

# Toggle the global error handler (defaults to true in production).
# NEXT_PUBLIC_ENABLE_GLOBAL_ERROR_HANDLER=true

# Disable slug proxy (set to n/off/0 to block random subdomains).
# SLUGS=n